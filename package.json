{
  "name": "gollm-service",
  "version": "0.3.0",
  "description": "Universal OpenAI-compatible LLM Microservice for OpenClaw & Hermes (Web Gemini RPA)",
  "type": "module",
  "main": "./dist/server/http-server.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gollm-service": "./dist/server/http-server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsx watch src/server/http-server.ts",
    "start": "node --import tsx src/server/http-server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/**/*.test.ts",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^8.0.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "gemini",
    "playwright",
    "rpa",
    "llm",
    "microservice",
    "openai-compatible",
    "ollama-alternative"
  ],
  "license": "MIT"
}
